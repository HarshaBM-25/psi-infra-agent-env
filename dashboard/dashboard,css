body{
background:#0f1117;
color:#e8eaf0;
font-family:Arial;
margin:0;
}

.container{
max-width:1200px;
margin:auto;
padding:20px;
}

header{
display:flex;
justify-content:space-between;
align-items:center;
}

.badge{
padding:4px 10px;
border-radius:20px;
font-size:12px;
}

.live{
background:#1f7a3a;
}

.task{
background:#2a5bd7;
}

.metrics{
display:grid;
grid-template-columns:repeat(5,1fr);
gap:10px;
margin-top:20px;
}

.metric{
background:#161b27;
padding:10px;
border-radius:8px;
}

.metric span{
font-size:12px;
color:#aaa;
}

.metric h2{
margin:5px 0;
}

.charts{
display:grid;
grid-template-columns:1fr 1fr;
gap:20px;
margin-top:20px;
}

.chart{
background:#161b27;
padding:15px;
border-radius:8px;
}

.pods{
margin-top:20px;
background:#161b27;
padding:15px;
border-radius:8px;
}

#pod-grid{
display:flex;
flex-wrap:wrap;
gap:6px;
}

.pod{
width:40px;
height:40px;
border-radius:6px;
display:flex;
align-items:center;
justify-content:center;
font-size:12px;
}

.running{
background:#2f8f4e;
}

.crashed{
background:#b34141;
}

.log{
margin-top:20px;
background:#161b27;
padding:15px;
border-radius:8px;
}

#agent-log{
max-height:160px;
overflow:auto;
font-family:monospace;
font-size:12px;
}

.controls{
margin-top:20px;
display:flex;
gap:10px;
}

button{
padding:8px 14px;
border:none;
background:#2a5bd7;
color:white;
border-radius:6px;
cursor:pointer;
}